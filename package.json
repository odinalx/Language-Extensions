{
  "name": "webtoon-korean-reader",
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-assets.mjs && node scripts/bundle-sandbox.mjs && wxt prepare",
    "bundle:sandbox": "node scripts/bundle-sandbox.mjs",
    "dev": "npm run bundle:sandbox && wxt",
    "build": "npm run bundle:sandbox && wxt build",
    "zip": "npm run bundle:sandbox && wxt zip"
  },
  "dependencies": {
    "kiwi-nlp": "^0.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@wxt-dev/module-react": "^1.1.0",
    "typescript": "~5.5.3",
    "wxt": "^0.19.0"
  },
  "overrides": {
    "@wxt-dev/module-react": {
      "@vitejs/plugin-react": "^5.1.0"
    }
  }
}
